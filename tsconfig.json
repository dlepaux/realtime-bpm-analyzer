{
  "compilerOptions": {
    "target": "ES2015",
    "module": "preserve",
    "lib": ["dom", "dom.iterable", "es2018"],
    "skipLibCheck": true,
    "declaration": true,
    "strict": true,
    "moduleResolution": "bundler",
    "sourceMap": true,
    "types": ["mocha"]
  },
  "include": [
    "tests/**/*.ts",
    "testing/**/*.ts",
    "github-pages/*.ts",
    "types/*.ts",
    "src/*.ts",
    "processor/*.ts"
  ],
  "exclude": ["node_modules"]
}
